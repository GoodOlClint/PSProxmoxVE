[global]
keyboard = "en-us"
country = "us"
fqdn = "pve-test.local"
mailto = "test@test.local"
timezone = "UTC"
root_password = "${root_password}"

[network]
source = "from-answer"
cidr = "${cidr}"
dns = "${dns}"
gateway = "${gateway}"
filter.ID_NET_NAME = "*"

[disk-setup]
filesystem = "ext4"
disk_list = ["sda"]
